# Required
TELEGRAM_BOT_TOKEN=
# Either name works — config.py reads TELEGRAM_CHAT_ID first, then falls
# back to TELEGRAM_GROUP_ID. Fill in whichever matches your GitHub secret.
TELEGRAM_CHAT_ID=
TELEGRAM_GROUP_ID=

# Topic thread IDs (integer, from supergroup topic URL)
TOPIC_EGYPT=
TOPIC_GULF=
TOPIC_REMOTE=
TOPIC_SOC=
TOPIC_PENTEST=
TOPIC_APPSEC=
TOPIC_CLOUDSEC=
TOPIC_GRC=
TOPIC_SECENG=
TOPIC_NETWORKSEC=
TOPIC_INTERNSHIPS=
# Optional, isolated topic for TELEGRAM_CANARY=true.  Real jobs are never sent here.
TOPIC_TEST=

# Optional API keys
ANTHROPIC_API_KEY=
RAPIDAPI_KEY=
SERPAPI_KEY=
LINKEDIN_COOKIES=
LI_AT=

# Optional health report destination
HEALTH_REPORT_CHAT_ID=

# Runtime controls
LINKEDIN_TOTAL_BUDGET_SECONDS=600
LINKEDIN_QUERY_CONCURRENCY=6
LINKEDIN_PAGES_PER_QUERY=4
LINKEDIN_DETAILS_PER_QUERY=6
LINKEDIN_POOL_CAP_RATIO=0.60
NON_LINKEDIN_POOL_FLOOR_RATIO=0.40
MIN_POOL_SIZE=5
ENABLE_SOURCE_LINKEDIN_HR_POSTS=false
ENABLE_SOURCE_REMOTIVE_SECURITY=true
ENABLE_SOURCE_REMOTEOK_SECURITY=true
ENABLE_SOURCE_WWR_SECURITY=true
ENABLE_SOURCE_ARBEITNOW_SECURITY=true
# Browser marketplace pages can be WAF/session-bound. Keep them out of the
# production plan; enable only when diagnosing one specific public page.
ENABLE_LEGACY_MARKETPLACE_SOURCES=false
STRICT_PUBLIC_ONLY=true
# v56: was "true" — that silently discarded every run's pool and never
# marked jobs seen, so nothing was ever sent no matter how many times the
# bot ran. Set to "true" again only if you deliberately want a dry test.
DRY_RUN=false
TELEGRAM_CANARY=false
ENABLE_LOCAL_ML_RETRAIN=false
ENABLE_TRAINING_DATA_COLLECTION=true

# Optional rotating-proxy pool (comma-separated). Leave empty for the
# default direct-only connection mode.
# PROXIES=http://user:pass@1.2.3.4:8000,http://user:pass@5.6.7.8:8000
PROXIES=
# Leave false for the free public-API mode. Set true only with a verified,
# working proxy pool that is genuinely needed for a non-API source.
ENABLE_PROXY_POOL=false
